Plan Course Completion Order

A university in Chennai offers n courses labeled from 0 to n-1. Some courses have prerequisites.

For example:

[1, 0] → To take course 1, you must first complete course 0

You must determine a valid order to complete all courses.

If possible → print one valid order
If not possible (cycle exists) → print -1
Input format :
First line: integer n → number of courses
Second line: integer m → number of prerequisite pairs
Next m lines: two integers a b
meaning: b → a (b must be done before a)

Output format :
Print course order (space-separated)
If impossible → print -1

Code constraints :
1 <= n <= 2000
0 <= m <= 5000
No duplicate edges
Sample test cases :

Input 1 :
4
4
1 0
2 0
3 1
3 2
Output 1 :
0 1 2 3
Input 2 :
2
1
1 0
Output 2 :
0 1


Solution:

// You are using GCC
#include<bits/stdc++.h>
using namespace std;

int main(){
    
    int n,m;
    cin>>n>>m;
    
    vector<vector<int>>adj(n);
    
    for(int i=0;i<m;i++){
        int u,v;
        cin>>u>>v;
        
        adj[u].push_back(v);
    }
    
    
    vector<int>indegree(n);
    
    for(int i=0;i<n;i++){
        for(int nei:adj[i]){
            indegree[nei]++;
        }
    }
    
    
    
    
    queue<int>que;
    
    for(int i=0;i<n;i++){
        if(indegree[i] == 0){
            que.push(i);
        }
    }
    
    vector<int>order;
    
    while(!que.empty()){
        
        int node = que.front();
        que.pop();
        
        order.push_back(node);
        
        for(int nei:adj[node]){
            indegree[nei]--;
            
            if(indegree[nei] == 0){
                que.push(nei);
            }
        }
    }
    
    
    if(order.size() != n){
        cout<<"-1";
        return 0;
    }
    
    for(int i:order){
        cout<<i<<" ";
    }
}
