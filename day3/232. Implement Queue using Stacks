Solution:


#include<bits/stdc++.h>
using namespace std;

class MyQueue {
    stack<int> s1, s2;

public:
    void push(int x) {
        s1.push(x);
        cout << x << " added\n";
    }

    void transfer() {
        if (s2.empty()) {
            while (!s1.empty()) {
                s2.push(s1.top());
                s1.pop();
            }
        }
    }

    void pop() {
        transfer();

        if (s2.empty()) {
            cout << "Queue is empty\n";
            return;
        }

        cout << s2.top() << " removed\n";
        s2.pop();
    }

    void peek() {
        transfer();

        if (s2.empty()) {
            cout << "Queue is empty\n";
            return;
        }

        cout << s2.top() << " at top\n";
    }

    void empty() {
        cout << ((s1.empty() && s2.empty()) ? "True" : "False") << "\n";
    }
};

int main() {

    int q;
    cin >> q;

    MyQueue obj;

    while (q--) {
        int type;
        cin >> type;

        if (type == 1) {
            int x;
            cin >> x;
            obj.push(x);
        }
        else if (type == 2) {
            obj.pop();
        }
        else if (type == 3) {
            obj.peek();
        }
        else if (type == 4) {
            obj.empty();
        }
    }

    return 0;
}
