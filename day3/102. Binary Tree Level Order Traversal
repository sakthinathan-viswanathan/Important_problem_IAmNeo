Printing Server Layers in a Network

A distributed system in Chennai represents its infrastructure as a binary tree, where each node is a server.

To monitor performance, engineers want to analyze servers level by level — i.e., all servers at depth 0, then depth 1, then depth 2, and so on.

Input format :
First line: integer n
Second line: n space-separated integers (level-order input)
Use -1 for NULL nodes
Output format :
Print the data level by level with their levels (refer sample output)

Code constraints :
0 <= n <= 2000
-1000 <= node value <= 1000

Sample test cases :
Input 1 :
6
1 2 3 4 -1 -1 5
Output 1 :
Level 0: 1
Level 1: 2 3
Level 2: 4
Input 2 :
7
10 20 30 -1 40 50 -1
Output 2 :
Level 0: 10
Level 1: 20 30
Level 2: 40 50


Solution:


#include<bits/stdc++.h>
using namespace std;

class Node{
    public:
    
    int data;
    Node* left ;
    Node* right;
    
    Node(int val){
        data = val;
        left = right = nullptr;
    }
};

Node* insert(vector<int> &arr,int n,int i){
    
    if(i >= n || arr[i] == -1){
        return nullptr;
    }
    
    Node* nn = new Node(arr[i]);
    
    nn->left = insert(arr,n,i*2+1);
    nn->right = insert(arr,n,i*2+2);
    
    return nn;
}


void LevelOrderTraversal(Node* root){
    
    if(root == nullptr){
        return ;
    }
    
    queue<Node*>que;
    que.push(root);
    
    int level = 0;
    
    while(!que.empty()){
        
        int n = que.size();
        
        
        cout<<"Level "<<level++<<": ";
        for(int i=0;i<n;i++){
            Node* node = que.front();
            que.pop();
            
            cout<<node->data<<" ";
            
            if(node->left != nullptr){
                que.push(node->left);
            }
            
            if(node->right != nullptr){
                que.push(node->right);
            }
        }
        
        cout<<endl;
    }
    
}

int main(){
    
    int n;
    cin>>n;
    
    vector<int>arr(n);
    
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    
    Node* root = insert(arr,n,0);
    
    LevelOrderTraversal(root);
}
